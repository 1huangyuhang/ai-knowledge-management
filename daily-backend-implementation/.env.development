# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# JWT Configuration
JWT_SECRET=dev-secret-key-1234567890
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Database Configuration
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cognitive_assistant_dev
DB_USERNAME=root
DB_PASSWORD=
DB_PATH=./database-dev.db

# Logging Configuration
LOG_LEVEL=debug
LOG_PRETTY=true

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60000

# CORS Configuration
CORS_ORIGIN=*

# AI Configuration
AI_API_KEY=dev-ai-api-key
AI_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-ada-002

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0